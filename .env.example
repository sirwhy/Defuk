# Privy Configuration
# Get your free App ID at https://dashboard.privy.io
# 
# Privy provides:
# - Email login
# - Phone login  
# - Social login (Google, Apple, etc.)
# - Embedded wallet
# - No MetaMask required for users!
#
# Sign up free at: https://privy.io

NEXT_PUBLIC_PRIVY_APP_ID=your_Privy_App_ID_here

